{
  "name": "@nataliapc/mcp-openmsx",
  "version": "1.2.8",
  "description": "Model context protocol server for openMSX automation and control",
  "main": "dist/server.js",
  "type": "module",
  "bin": {
    "mcp-openmsx": "dist/server.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "openmsx",
    "msx",
    "emulator",
    "automation",
    "retro-computing"
  ],
  "author": "Natalia Pujol Cremades <info@abitwitches.com>",
  "license": "GPL2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nataliapc/mcp-openmsx.git"
  },
  "bugs": {
    "url": "https://github.com/nataliapc/mcp-openmsx/issues"
  },
  "homepage": "https://github.com/nataliapc/mcp-openmsx#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "node_modules/.bin/tsc && shx chmod +x dist/server.js",
    "watch": "node_modules/.bin/tsc --watch",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "optionalDependencies": {
    "node-expose-sspi": "^0.1.60",
    "sharp": ">=0.32.0"
  },
  "pnpm": {
    "overrides": {
      "sharp": "$sharp"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@themaximalist/embeddings.js": "^0.1.3",
    "@types/express": "^5.0.6",
    "@types/mime-types": "^3.0.1",
    "@xenova/transformers": "^2.17.2",
    "debug": "^4.4.3",
    "express": "^5.2.1",
    "mime-types": "^3.0.2",
    "sanitize-html": "^2.17.0",
    "tsx": "^4.21.0",
    "vectra": "^0.11.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.20.0",
    "@types/node": "^25.2.3",
    "@types/sanitize-html": "^2.16.0",
    "@vitest/coverage-v8": "^4.1.4",
    "shx": "^0.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "files": [
    "dist/**/*",
    "resources/**/*",
    "vector-db/**/*",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
